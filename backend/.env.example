# DBA Dash DB Connection
DBADASH_SERVER=your-sql-server
DBADASH_DATABASE=DBADashDB
DBADASH_DRIVER=ODBC Driver 18 for SQL Server

# Use Windows Auth (leave user/pass empty) or SQL Auth
DBADASH_USER=
DBADASH_PASSWORD=
DBADASH_TRUSTED_CONNECTION=yes

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
